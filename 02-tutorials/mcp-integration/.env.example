# Copy this file to .env and fill in the placeholders. .env is gitignored.
# Real values only at runtime — never commit a populated .env.

# --- Vertex AI / GCP ---
# Your Google Cloud project (user-specific — replace).
GOOGLE_CLOUD_PROJECT=your-project-id
# "global" is recommended for Claude on Vertex (dynamic routing, no premium).
GOOGLE_CLOUD_REGION=global
# Current Claude model id on Vertex (no @date suffix for current models).
CLAUDE_MODEL_ID=claude-opus-4-8

# --- BigQuery managed MCP server ---
# Fixed public endpoint for the managed remote BigQuery MCP server.
BQ_MCP_ENDPOINT=https://bigquery.googleapis.com/mcp
# Public dataset used by the tutorial so it runs without private data.
BQ_DATASET=bigquery-public-data

# --- Agent Engine deploy (notebook 04) ---
# GCS staging bucket for the Agent Engine build (user-specific — replace).
STAGING_BUCKET=gs://your-staging-bucket
# Agent Engine deploy region. Must be a concrete region (NOT "global"); pick one
# where both Agent Engine and your Claude model are available, e.g. us-central1.
# The deployed agent still calls Claude on the GOOGLE_CLOUD_REGION endpoint above.
AGENT_ENGINE_LOCATION=us-central1
